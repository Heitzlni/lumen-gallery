<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/vault_album_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/tiny_margin"
    android:clickable="true"
    android:focusable="true"
    android:paddingStart="@dimen/activity_margin"
    android:paddingEnd="@dimen/activity_margin"
    android:paddingTop="@dimen/medium_margin"
    android:paddingBottom="@dimen/medium_margin">

    <ImageView
        android:id="@+id/vault_album_thumb"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_centerVertical="true"
        android:background="@android:color/black"
        android:scaleType="centerCrop"
        tools:src="@drawable/ic_files_vector" />

    <org.fossify.commons.views.MyTextView
        android:id="@+id/vault_album_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/medium_margin"
        android:layout_toEndOf="@+id/vault_album_thumb"
        android:ellipsize="middle"
        android:maxLines="1"
        android:textSize="@dimen/bigger_text_size"
        android:textStyle="bold"
        tools:text="Vacation" />

    <org.fossify.commons.views.MyTextView
        android:id="@+id/vault_album_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/vault_album_name"
        android:layout_marginStart="@dimen/medium_margin"
        android:layout_toEndOf="@+id/vault_album_thumb"
        android:alpha="0.7"
        android:maxLines="1"
        android:textSize="@dimen/smaller_text_size"
        tools:text="12 items" />

</RelativeLayout>
